# OASE - Variables d'environnement PRODUCTION (template)
# ============================================================
# Sur le VPS : cp env.prod.template .env
# Puis editer avec les vraies valeurs avant `docker compose up`.
# ============================================================

# --- API ---
NODE_ENV=production
PORT=3000
DATABASE_URL=mysql://oase:CHANGE_ME_DB_PASS@oase-db:3306/oase?charset=utf8mb4

# --- JWT ---
# Generer avec : openssl rand -hex 32
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS_RANDOM
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_MIN_32_CHARS_RANDOM
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# --- DB ---
DB_ROOT_PASSWORD=CHANGE_ME_DB_ROOT_PASSWORD
DB_NAME=oase
DB_USER=oase
DB_PASS=CHANGE_ME_DB_PASS

# --- CORS ---
CORS_ORIGINS=https://oase.ulia.site,https://api.oase.ulia.site

# --- Logs ---
LOG_LEVEL=info
