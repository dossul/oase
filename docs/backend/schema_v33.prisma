  @@index([impot_concerne], map: "idx_impot_concerne")
  @@index([nature_mesure_code], map: "idx_nature_mesure_code")
  @@index([periode_annee, periode_mois], map: "idx_periode")
  @@index([type_texte_1], map: "idx_type_texte_1")
  @@index([regime_code], map: "regime_code")
  @@index([type_beneficiaire_code], map: "type_beneficiaire_code")
}

model reporting_executions {
  id                String            @id @default(dbgenerated("(uuid())")) @db.Char(36)
  type_rapport_code String            @db.VarChar(50)
  periode_annee     Int
  periode_mois      Int?
  parametres        Json?
  fichier_url       String?           @db.VarChar(500)
  hash_fichier      String?           @db.Char(64)
  est_programme     Boolean           @default(false)
  date_debut        DateTime          @default(now())
  date_fin          DateTime?
  statut_code       String            @default("pending") @db.VarChar(50)
  message_erreur    String?           @db.Text
  created_at        DateTime          @default(now())
  ref_types_rapport ref_types_rapport @relation(fields: [type_rapport_code], references: [code], onUpdate: NoAction, map: "reporting_executions_ibfk_1")
  ref_etats_job     ref_etats_job     @relation(fields: [statut_code], references: [code], onUpdate: NoAction, map: "reporting_executions_ibfk_2")

  @@index([periode_annee, periode_mois], map: "idx_periode")
  @@index([statut_code], map: "idx_statut_code")
  @@index([type_rapport_code], map: "idx_type_rapport_code")
}

model reset_password_tokens {
  id             String       @id @default(dbgenerated("(uuid())")) @db.Char(36)
  utilisateur_id String       @db.Char(36)
  token_hash     String       @unique(map: "token_hash") @db.Char(64)
  expires_at     DateTime
  est_utilise    Boolean      @default(false)
  created_at     DateTime     @default(now())
  utilisateurs   utilisateurs @relation(fields: [utilisateur_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "reset_password_tokens_ibfk_1")

  @@index([utilisateur_id], map: "idx_utilisateur_id")
}

model roles_permissions {
  role       String    @db.VarChar(50)
  ressource  String    @db.VarChar(50)
  action     String    @db.VarChar(50)
  perimetre  String?   @db.VarChar(100)
  created_at DateTime  @default(now())
  ref_roles  ref_roles @relation(fields: [role], references: [code], onDelete: Cascade, onUpdate: NoAction, map: "fk_rolesperm_role")

  @@id([role, ressource, action])
  @@index([role], map: "idx_role")
}

model sessions_utilisateur {
  id                     String       @id @default(dbgenerated("(uuid())")) @db.Char(36)
  utilisateur_id         String       @db.Char(36)
  jeton_session_hash     String       @unique(map: "jeton_session_hash") @db.Char(64)
  ip                     String?      @db.VarChar(45)
  user_agent             String?      @db.Text
  pays                   String?      @db.VarChar(100)
  ville                  String?      @db.VarChar(100)
  date_connexion         DateTime     @default(now())
  date_derniere_activite DateTime     @default(now())
  date_deconnexion       DateTime?
  est_active             Boolean      @default(true)
  created_at             DateTime     @default(now())
  utilisateurs           utilisateurs @relation(fields: [utilisateur_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "sessions_utilisateur_ibfk_1")

  @@index([est_active], map: "idx_est_active")
  @@index([jeton_session_hash], map: "idx_jeton_session_hash")
  @@index([utilisateur_id], map: "idx_utilisateur_id")
}

model system_logs {
  id         String   @id @default(dbgenerated("(uuid())")) @db.Char(36)
  niveau     String   @db.VarChar(20)
  source     String   @db.VarChar(100)
  message    String   @db.Text
  contexte   Json?
  trace      String?  @db.Text
  created_at DateTime @default(now())

  @@index([created_at], map: "idx_created_at")
  @@index([niveau], map: "idx_niveau")
  @@index([source], map: "idx_source")
}

model utilisateurs {
  id                       String                     @id @default(dbgenerated("(uuid())")) @db.Char(36)
  nom                      String                     @db.VarChar(100)
  prenom                   String                     @db.VarChar(100)
  email                    String                     @unique(map: "email") @db.VarChar(200)
  password_hash            String                     @db.VarChar(255)
  role                     String                     @db.VarChar(50)
  institution_id           String                     @db.Char(36)
  statut_code              String                     @default("actif") @db.VarChar(50)
  mfa_active               Boolean                    @default(true)
  mfa_secret_enc           String?                    @db.VarChar(500)
  pin_hash                 String?                    @db.VarChar(60)
  secteur_affecte          String?                    @db.VarChar(100)
  telephone                String?                    @db.VarChar(20)
  derniere_connexion       DateTime?
  ip_derniere_cx           String?                    @db.VarChar(45)
  created_at               DateTime                   @default(now())
  updated_at               DateTime                   @default(now())
  anomalies                anomalies[]
  audit_logs               audit_logs[]
  base_juridique_documents base_juridique_documents[]
  beneficiaires            beneficiaires?
  decisions                decisions[]
  demande_complements      demande_complements[]
  demande_workflow_etapes  demande_workflow_etapes[]
  demandes                 demandes[]
  imports_mrd              imports_mrd[]
  notification_preferences notification_preferences[]
  notification_queue       notification_queue[]
  notifications            notifications[]
  pieces_jointes           pieces_jointes[]
  push_tokens              push_tokens[]
  refresh_tokens           refresh_tokens[]
  reset_password_tokens    reset_password_tokens[]
  sessions_utilisateur     sessions_utilisateur[]
  ref_roles                ref_roles                  @relation(fields: [role], references: [code], onUpdate: NoAction, map: "fk_utilisateurs_role")
  institutions             institutions               @relation(fields: [institution_id], references: [id], onUpdate: NoAction, map: "utilisateurs_ibfk_1")
  ref_statuts_utilisateur  ref_statuts_utilisateur    @relation(fields: [statut_code], references: [code], onUpdate: NoAction, map: "utilisateurs_ibfk_2")

  @@index([email], map: "idx_email")
  @@index([institution_id], map: "idx_institution_id")
  @@index([role], map: "idx_role")
  @@index([statut_code], map: "idx_statut_code")
}

model workflow_template_etapes {
  id                      String                    @id @default(dbgenerated("(uuid())")) @db.Char(36)
  workflow_template_id    String                    @db.Char(36)
  nom_etape               String                    @db.VarChar(200)
  ordre                   Int
  acteur_role             String                    @db.VarChar(50)
  institution_type_code   String?                   @db.VarChar(50)
  delai_cible_jours       Int?
  pin_requis              Boolean                   @default(false)
  est_obligatoire         Boolean                   @default(true)
  condition_activation    String?                   @db.Text
  action_declenchee       String?                   @db.VarChar(100)
  created_at              DateTime                  @default(now())
  demande_workflow_etapes demande_workflow_etapes[]
  workflow_templates      workflow_templates        @relation(fields: [workflow_template_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "workflow_template_etapes_ibfk_1")
  ref_types_institution   ref_types_institution?    @relation(fields: [institution_type_code], references: [code], onUpdate: NoAction, map: "workflow_template_etapes_ibfk_2")

  @@unique([workflow_template_id, ordre], map: "uk_workflow_etape_ordre")
  @@index([workflow_template_id, ordre], map: "idx_workflow_template_etapes_template_ordre")
  @@index([workflow_template_id], map: "idx_workflow_template_id")
  @@index([institution_type_code], map: "institution_type_code")
}

model workflow_template_transitions {
  id                   String             @id @default(dbgenerated("(uuid())")) @db.Char(36)
  workflow_template_id String             @db.Char(36)
  etape_source_ordre   Int
  etape_cible_ordre    Int
  action               String             @db.VarChar(100)
  condition_transition String?            @db.Text
  created_at           DateTime           @default(now())
  workflow_templates   workflow_templates @relation(fields: [workflow_template_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "workflow_template_transitions_ibfk_1")

  @@index([workflow_template_id], map: "idx_workflow_template_id")
}

model workflow_templates {
  id                            String                          @id @default(dbgenerated("(uuid())")) @db.Char(36)
  code                          String                          @unique(map: "code") @db.VarChar(50)
  nom                           String                          @db.VarChar(100)
  description                   String?                         @db.Text
  base_juridique_version_id     String?                         @db.Char(36)
  type_texte_1                  String                          @db.VarChar(100)
  organe_gestion_code           String?                         @db.VarChar(50)
  est_actif                     Boolean                         @default(true)
  version_template              Int                             @default(1)
  created_at                    DateTime                        @default(now())
  updated_at                    DateTime                        @default(now())
  demande_workflow_instances    demande_workflow_instances[]
  workflow_template_etapes      workflow_template_etapes[]
  workflow_template_transitions workflow_template_transitions[]
  base_juridique_versions       base_juridique_versions?        @relation(fields: [base_juridique_version_id], references: [id], onUpdate: NoAction, map: "workflow_templates_ibfk_1")
  ref_organes_gestion           ref_organes_gestion?            @relation(fields: [organe_gestion_code], references: [code], onUpdate: NoAction, map: "workflow_templates_ibfk_2")

  @@index([base_juridique_version_id], map: "idx_base_juridique_version_id")
  @@index([organe_gestion_code], map: "idx_organe_gestion_code")
  @@index([type_texte_1], map: "idx_type_texte_1")
}
