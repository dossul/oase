generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model accords_siege {
  id                     String                 @id @default(dbgenerated("(uuid())")) @db.Char(36)
  institution            String                 @db.VarChar(200)
  type_institution_code  String                 @db.VarChar(50)
  texte_fondateur        String?                @db.Text
  date_signature         DateTime?              @db.Date
  est_actif              Boolean                @default(true)
  created_at             DateTime               @default(now())
  ref_types_accord_siege ref_types_accord_siege @relation(fields: [type_institution_code], references: [code], onUpdate: NoAction, map: "accords_siege_ibfk_1")
  beneficiaires          beneficiaires[]
  conventions            conventions[]

  @@index([type_institution_code], map: "idx_type_institution_code")
}

model actes {
  id                String         @id @default(dbgenerated("(uuid())")) @db.Char(36)
  demande_id        String         @db.Char(36)
  decision_id       String?        @db.Char(36)
  type_code         String         @db.VarChar(50)
  reference         String         @unique(map: "reference") @db.VarChar(50)
  beneficiaire_id   String         @db.Char(36)
  montant_fcfa      BigInt?
  date_effet        DateTime       @db.Date
  document_url      String         @db.VarChar(500)
  hash_document     String         @db.Char(64)
  qr_code_hash      String         @db.Char(64)
  qr_code_image_url String?        @db.VarChar(500)
  est_revoke        Boolean        @default(false)
  date_revocation   DateTime?
  motif_revocation  String?        @db.Text
  created_at        DateTime       @default(now())
  demandes          demandes       @relation(fields: [demande_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "actes_ibfk_1")
  decisions         decisions?     @relation(fields: [decision_id], references: [id], onUpdate: NoAction, map: "actes_ibfk_2")
  ref_types_acte    ref_types_acte @relation(fields: [type_code], references: [code], onUpdate: NoAction, map: "actes_ibfk_3")
  beneficiaires     beneficiaires  @relation(fields: [beneficiaire_id], references: [id], onUpdate: NoAction, map: "actes_ibfk_4")

  @@index([demande_id, type_code], map: "idx_actes_demande_type")
  @@index([beneficiaire_id], map: "idx_beneficiaire_id")
  @@index([decision_id], map: "idx_decision_id")
  @@index([demande_id], map: "idx_demande_id")
  @@index([qr_code_hash], map: "idx_qr_code_hash")
  @@index([reference], map: "idx_reference")
  @@index([type_code], map: "idx_type_code")
}

model agrement_beneficiaires {
  id              String        @id @default(dbgenerated("(uuid())")) @db.Char(36)
  agrement_id     String        @db.Char(36)
  beneficiaire_id String        @db.Char(36)
  role            String?       @db.VarChar(50)
  created_at      DateTime      @default(now())
  agrements       agrements     @relation(fields: [agrement_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "agrement_beneficiaires_ibfk_1")
  beneficiaires   beneficiaires @relation(fields: [beneficiaire_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "agrement_beneficiaires_ibfk_2")

  @@unique([agrement_id, beneficiaire_id], map: "uk_agrement_beneficiaire")
  @@index([agrement_id], map: "idx_agrement_id")
  @@index([beneficiaire_id], map: "idx_beneficiaire_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model agrements {
  id                        String                   @id @default(dbgenerated("(uuid())")) @db.Char(36)
  reference                 String                   @unique(map: "reference") @db.VarChar(30)
  beneficiaire_id           String                   @db.Char(36)
  type_agrement_code        String                   @db.VarChar(50)
  base_juridique_version_id String?                  @db.Char(36)
  regime_code               String?                  @db.VarChar(50)
  statut_code               String                   @default("active") @db.VarChar(50)
  date_debut                DateTime                 @db.Date
  date_fin                  DateTime                 @db.Date
  montant_estime            BigInt?
  objet                     String?                  @db.Text
  document_url              String?                  @db.VarChar(500)
  hash_document             String?                  @db.Char(64)
  created_at                DateTime                 @default(now())
  updated_at                DateTime                 @default(now())
  agrement_beneficiaires    agrement_beneficiaires[]
  beneficiaires             beneficiaires            @relation(fields: [beneficiaire_id], references: [id], onUpdate: NoAction, map: "agrements_ibfk_1")
  ref_types_agrement        ref_types_agrement       @relation(fields: [type_agrement_code], references: [code], onUpdate: NoAction, map: "agrements_ibfk_2")
  base_juridique_versions   base_juridique_versions? @relation(fields: [base_juridique_version_id], references: [id], onUpdate: NoAction, map: "agrements_ibfk_3")
  ref_regimes_convention    ref_regimes_convention?  @relation(fields: [regime_code], references: [code], onUpdate: NoAction, map: "agrements_ibfk_4")
  ref_statuts_convention    ref_statuts_convention   @relation(fields: [statut_code], references: [code], onUpdate: NoAction, map: "agrements_ibfk_5")

  @@index([base_juridique_version_id], map: "idx_base_juridique_version_id")
  @@index([beneficiaire_id], map: "idx_beneficiaire_id")
  @@index([statut_code], map: "idx_statut_code")
  @@index([type_agrement_code], map: "idx_type_agrement_code")
  @@index([regime_code], map: "regime_code")
}

model anomalies {
  id                        String                   @id @default(dbgenerated("(uuid())")) @db.Char(36)
  categorie_code            String                   @db.VarChar(50)
  gravite_code              String                   @db.VarChar(50)
  description               String                   @db.Text
  demande_id                String?                  @db.Char(36)
  base_juridique_version_id String?                  @db.Char(36)
  convention_id             String?                  @db.Char(36)
  date_detection            DateTime                 @default(now())
  statut_code               String                   @default("nouvelle") @db.VarChar(50)
  detectee_par_code         String                   @db.VarChar(50)
  utilisateur_id            String?                  @db.Char(36)
  regle_id                  String?                  @db.VarChar(100)
  commentaire               String?                  @db.Text
  date_resolution           DateTime?
  created_at                DateTime                 @default(now())
  updated_at                DateTime                 @default(now())
  demandes                  demandes?                @relation(fields: [demande_id], references: [id], onUpdate: NoAction, map: "anomalies_ibfk_1")
  base_juridique_versions   base_juridique_versions? @relation(fields: [base_juridique_version_id], references: [id], onUpdate: NoAction, map: "anomalies_ibfk_2")
  conventions               conventions?             @relation(fields: [convention_id], references: [id], onUpdate: NoAction, map: "anomalies_ibfk_3")
  utilisateurs              utilisateurs?            @relation(fields: [utilisateur_id], references: [id], onUpdate: NoAction, map: "anomalies_ibfk_4")
  ref_categories_anomalie   ref_categories_anomalie  @relation(fields: [categorie_code], references: [code], onUpdate: NoAction, map: "anomalies_ibfk_5")
  ref_gravites_anomalie     ref_gravites_anomalie    @relation(fields: [gravite_code], references: [code], onUpdate: NoAction, map: "anomalies_ibfk_6")
  ref_statuts_anomalie      ref_statuts_anomalie     @relation(fields: [statut_code], references: [code], onUpdate: NoAction, map: "anomalies_ibfk_7")
  ref_sources_detection     ref_sources_detection    @relation(fields: [detectee_par_code], references: [code], onUpdate: NoAction, map: "anomalies_ibfk_8")
  regles_anomalie           regles_anomalie?         @relation(fields: [regle_id], references: [code], onUpdate: NoAction, map: "fk_anomalies_regle")

  @@index([regle_id], map: "fk_anomalies_regle")
  @@index([demande_id, gravite_code], map: "idx_anomalies_demande_gravite")
  @@index([base_juridique_version_id], map: "idx_base_juridique_version_id")
  @@index([categorie_code], map: "idx_categorie_code")
  @@index([convention_id], map: "idx_convention_id")
  @@index([demande_id], map: "idx_demande_id")
  @@index([detectee_par_code], map: "idx_detectee_par_code")
  @@index([gravite_code, statut_code], map: "idx_gravite_code_statut_code")
  @@index([statut_code], map: "statut_code")
  @@index([utilisateur_id], map: "utilisateur_id")
}

model archivages {
  id                    String                @id @default(dbgenerated("(uuid())")) @db.Char(36)
  type_entite           String                @db.VarChar(50)
  entite_id             String                @db.Char(36)
  demande_id            String?               @db.Char(36)
  statut_code           String                @default("en_attente") @db.VarChar(50)
  chemin_archive        String?               @db.VarChar(500)
  hash_archive          String?               @db.Char(64)
  declenche_par         String                @default("systeme") @db.VarChar(50)
  date_archivage        DateTime?
  created_at            DateTime              @default(now())
  demandes              demandes?             @relation(fields: [demande_id], references: [id], onUpdate: NoAction, map: "archivages_ibfk_1")
  ref_statuts_archivage ref_statuts_archivage @relation(fields: [statut_code], references: [code], onUpdate: NoAction, map: "archivages_ibfk_2")

  @@index([demande_id], map: "idx_demande_id")
  @@index([statut_code], map: "idx_statut_code")
  @@index([type_entite, entite_id], map: "idx_type_entite_entite_id")
}

model audit_logs {
  id               String        @id @default(dbgenerated("(uuid())")) @db.Char(36)
  horodatage       DateTime      @default(now())
  utilisateur_id   String?       @db.Char(36)
  role_au_moment   String?       @db.VarChar(50)
  institution      String?       @db.VarChar(100)
  action           String        @db.VarChar(100)
  entite           String        @db.VarChar(50)
  entite_id        String        @db.Char(36)
  demande_id       String?       @db.Char(36)
  ancienne_valeur  Json?
  nouvelle_valeur  Json?
  ip               String?       @db.VarChar(45)
  user_agent       String?       @db.Text
  hash_precedent   String?       @db.Char(64)
  empreinte_sha256 String        @db.Char(64)
  created_at       DateTime      @default(now())
  utilisateurs     utilisateurs? @relation(fields: [utilisateur_id], references: [id], onUpdate: NoAction, map: "audit_logs_ibfk_1")
  demandes         demandes?     @relation(fields: [demande_id], references: [id], onUpdate: NoAction, map: "audit_logs_ibfk_2")

  @@index([action], map: "idx_action")
  @@index([action, entite], map: "idx_audit_logs_action_entite")
  @@index([demande_id], map: "idx_demande_id")
  @@index([entite, entite_id], map: "idx_entite_entite_id")
  @@index([horodatage], map: "idx_horodatage")
  @@index([utilisateur_id], map: "idx_utilisateur_id")
}

model base_juridique_documents {
  id                        String                  @id @default(dbgenerated("(uuid())")) @db.Char(36)
  base_juridique_version_id String                  @db.Char(36)
  type_document             String                  @db.VarChar(50)
  reference_document        String?                 @db.VarChar(200)
  date_document             DateTime?               @db.Date
  nom_fichier               String                  @db.VarChar(300)
  type_mime                 String                  @default("application/pdf") @db.VarChar(100)
  taille_octets             BigInt?
  url_stockage              String                  @db.VarChar(500)
  hash_sha256               String                  @db.Char(64)
  est_texte_fondateur       Boolean                 @default(false)
  est_public                Boolean                 @default(true)
  uploaded_by_id            String?                 @db.Char(36)
  created_at                DateTime                @default(now())
  updated_at                DateTime                @default(now())
  base_juridique_versions   base_juridique_versions @relation(fields: [base_juridique_version_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "base_juridique_documents_ibfk_1")
  utilisateurs              utilisateurs?           @relation(fields: [uploaded_by_id], references: [id], onUpdate: NoAction, map: "base_juridique_documents_ibfk_2")

  @@index([base_juridique_version_id], map: "idx_base_juridique_version_id")
  @@index([date_document], map: "idx_date_document")
  @@index([est_public], map: "idx_est_public")
  @@index([est_texte_fondateur], map: "idx_est_texte_fondateur")
  @@index([type_document], map: "idx_type_document")
  @@index([uploaded_by_id], map: "uploaded_by_id")
}

model base_juridique_versions {
  id                         String                     @id @default(dbgenerated("(uuid())")) @db.Char(36)
  base_juridique_id          String                     @db.Char(36)
  version                    Int                        @default(1)
  libelle                    String                     @db.Text
  impot_concerne             String                     @db.VarChar(100)
  nature_mesure_code         String                     @db.VarChar(50)
  type_texte_1               String?                    @db.VarChar(100)
  type_texte_2               String?                    @db.VarChar(50)
  support_juridique_base     String?                    @db.Text
  support_juridique_complem  String?                    @db.Text
  article                    String?                    @db.VarChar(200)
  article_cgi_2025           String?                    @db.VarChar(100)
  portee_categorie_code      String                     @default("Permanente") @db.VarChar(50)
  portee_duree_mois          Int?
  portee_description         String?                    @db.Text
  organe_gestion_code        String?                    @db.VarChar(50)
  organe_attribution         String?                    @db.VarChar(100)
  systeme_information        String?                    @db.VarChar(100)
  mode_instruction_code      String                     @default("manuel") @db.VarChar(50)
  objectif_type              String?                    @db.VarChar(50)
  branche_activite           String?                    @db.VarChar(100)
  type_beneficiaire_cible    String?                    @db.VarChar(100)
  est_depense_fiscale_2024   Boolean                    @default(false)
  est_evaluee_2024           Boolean                    @default(false)
  donnees_disponibles        Boolean                    @default(false)
  fonction_budgetaire        String?                    @db.VarChar(100)
  conformite_texte_fondament String?                    @db.VarChar(10)
  conformite_directive_uemoa String?                    @db.VarChar(10)
  odd                        String?                    @db.VarChar(20)
  programme_dotation         String?                    @db.VarChar(100)
  position_sh                String?                    @db.VarChar(50)
  est_active                 Boolean                    @default(true)
  date_adoption              DateTime?                  @db.Date
  date_abrogation            DateTime?                  @db.Date
  valid_from                 DateTime                   @default(now())
  valid_to                   DateTime?
  created_at                 DateTime                   @default(now())
  updated_at                 DateTime                   @default(now())
  version_courante_flag      Int?                       @db.TinyInt
  agrements                  agrements[]
  anomalies                  anomalies[]
  base_juridique_documents   base_juridique_documents[]
  bases_juridiques           bases_juridiques           @relation(fields: [base_juridique_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "base_juridique_versions_ibfk_1")
  ref_natures_mesure         ref_natures_mesure         @relation(fields: [nature_mesure_code], references: [code], onUpdate: NoAction, map: "base_juridique_versions_ibfk_2")
  ref_portees_categorie      ref_portees_categorie      @relation(fields: [portee_categorie_code], references: [code], onUpdate: NoAction, map: "base_juridique_versions_ibfk_3")
  ref_organes_gestion        ref_organes_gestion?       @relation(fields: [organe_gestion_code], references: [code], onUpdate: NoAction, map: "base_juridique_versions_ibfk_4")
  ref_modes_instruction      ref_modes_instruction      @relation(fields: [mode_instruction_code], references: [code], onUpdate: NoAction, map: "base_juridique_versions_ibfk_5")
  codes_additionnels         codes_additionnels[]
  conventions                conventions[]
  demandes                   demandes[]
  quotas                     quotas[]
  workflow_templates         workflow_templates[]

  @@unique([base_juridique_id, version], map: "uk_base_juridique_version")
  @@unique([base_juridique_id, version_courante_flag], map: "uk_une_seule_version_active")
  @@index([base_juridique_id], map: "idx_base_juridique_id")
  @@index([base_juridique_id, est_active, valid_to], map: "idx_base_juridique_versions_active")
  @@index([valid_from, valid_to], map: "idx_code_mesure_version")
  @@index([est_active, valid_to], map: "idx_est_active_valid_to")
  @@index([impot_concerne], map: "idx_impot_concerne")
  @@index([mode_instruction_code], map: "idx_mode_instruction_code")
  @@index([organe_gestion_code], map: "idx_organe_gestion_code")
  @@index([type_texte_1], map: "idx_type_texte_1")
  @@index([nature_mesure_code], map: "nature_mesure_code")
  @@index([portee_categorie_code], map: "portee_categorie_code")
  @@fulltext([libelle], map: "ft_bjv_libelle")
}

model bases_juridiques {
  id                      String                    @id @default(dbgenerated("(uuid())")) @db.Char(36)
  code_mesure             String                    @unique(map: "code_mesure") @db.VarChar(20)
  code_mesure_mrd         Int?
  created_at              DateTime                  @default(now())
  updated_at              DateTime                  @default(now())
  base_juridique_versions base_juridique_versions[]

  @@index([code_mesure], map: "idx_code_mesure")
  @@index([code_mesure_mrd], map: "idx_code_mesure_mrd")
}

model beneficiaire_historique_fiscal {
  id                 String             @id @default(dbgenerated("(uuid())")) @db.Char(36)
  beneficiaire_id    String             @db.Char(36)
  statut_fiscal_code String             @db.VarChar(50)
  date_debut         DateTime           @db.Date
  date_fin           DateTime?          @db.Date
  source             String?            @db.VarChar(100)
  connecteur_code    String?            @db.VarChar(50)
  created_at         DateTime           @default(now())
  beneficiaires      beneficiaires      @relation(fields: [beneficiaire_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "beneficiaire_historique_fiscal_ibfk_1")
  ref_statuts_fiscal ref_statuts_fiscal @relation(fields: [statut_fiscal_code], references: [code], onUpdate: NoAction, map: "beneficiaire_historique_fiscal_ibfk_2")
  connecteurs        connecteurs?       @relation(fields: [connecteur_code], references: [code_systeme], onUpdate: NoAction, map: "fk_histofiscal_connecteur")

  @@index([connecteur_code], map: "fk_histofiscal_connecteur")
  @@index([beneficiaire_id], map: "idx_beneficiaire_id")
  @@index([statut_fiscal_code], map: "idx_statut_fiscal_code")
}

model beneficiaires {
  id                             String                           @id @default(dbgenerated("(uuid())")) @db.Char(36)
  raison_sociale                 String                           @db.VarChar(200)
  nif                            String                           @unique(map: "nif") @db.VarChar(20)
  rccm                           String?                          @db.VarChar(30)
  type_beneficiaire_code         String                           @db.VarChar(50)
  statut_fiscal_code             String                           @default("inconnu") @db.VarChar(50)
  secteur                        String?                          @db.VarChar(100)
  region                         String?                          @db.VarChar(100)
  email_contact                  String?                          @db.VarChar(200)
  telephone                      String?                          @db.VarChar(20)
  adresse                        String?                          @db.Text
  accord_siege_id                String?                          @db.Char(36)
  user_id                        String?                          @unique(map: "user_id") @db.Char(36)
  created_at                     DateTime                         @default(now())
  updated_at                     DateTime                         @default(now())
  actes                          actes[]
  agrement_beneficiaires         agrement_beneficiaires[]
  agrements                      agrements[]
  beneficiaire_historique_fiscal beneficiaire_historique_fiscal[]
  accords_siege                  accords_siege?                   @relation(fields: [accord_siege_id], references: [id], onUpdate: NoAction, map: "beneficiaires_ibfk_1")
  ref_types_beneficiaire         ref_types_beneficiaire           @relation(fields: [type_beneficiaire_code], references: [code], onUpdate: NoAction, map: "beneficiaires_ibfk_2")
  ref_statuts_fiscal             ref_statuts_fiscal               @relation(fields: [statut_fiscal_code], references: [code], onUpdate: NoAction, map: "beneficiaires_ibfk_3")
  utilisateurs                   utilisateurs?                    @relation(fields: [user_id], references: [id], onUpdate: NoAction, map: "beneficiaires_ibfk_4")
  conventions                    conventions[]
  demandes                       demandes[]
  quotas                         quotas[]

  @@index([accord_siege_id], map: "idx_accord_siege_id")
  @@index([nif], map: "idx_nif")
  @@index([statut_fiscal_code], map: "idx_statut_fiscal_code")
  @@index([type_beneficiaire_code], map: "idx_type_beneficiaire_code")
  @@fulltext([raison_sociale], map: "ft_beneficiaires")
}

model codes_additionnels {
  id                        String                  @id @default(dbgenerated("(uuid())")) @db.Char(36)
  base_juridique_version_id String                  @db.Char(36)
  code                      String                  @db.VarChar(50)
  source_code               String                  @db.VarChar(50)
  est_principal             Boolean                 @default(true)
  created_at                DateTime                @default(now())
  base_juridique_versions   base_juridique_versions @relation(fields: [base_juridique_version_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "codes_additionnels_ibfk_1")
  ref_sources_code          ref_sources_code        @relation(fields: [source_code], references: [code], onUpdate: NoAction, map: "codes_additionnels_ibfk_2")

  @@index([base_juridique_version_id], map: "idx_base_juridique_version_id")
  @@index([code, source_code], map: "idx_code_source")
  @@index([source_code], map: "source_code")
}

model connecteur_logs {
  id              String      @id @default(dbgenerated("(uuid())")) @db.Char(36)
  connecteur_id   String      @db.Char(36)
  direction       String      @db.VarChar(10)
  operation       String      @db.VarChar(100)
  payload_entrant Json?
  payload_sortant Json?
  statut_http     Int?
  duree_ms        Int?
  est_erreur      Boolean     @default(false)
  message_erreur  String?     @db.Text
  created_at      DateTime    @default(now())
  connecteurs     connecteurs @relation(fields: [connecteur_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "connecteur_logs_ibfk_1")

  @@index([connecteur_id], map: "idx_connecteur_id")
  @@index([connecteur_id, created_at], map: "idx_connecteur_logs_connecteur_date")
  @@index([created_at], map: "idx_created_at")
  @@index([est_erreur], map: "idx_est_erreur")
  @@index([operation], map: "idx_operation")
}

model connecteurs {
  id                             String                           @id @default(dbgenerated("(uuid())")) @db.Char(36)
  nom                            String                           @db.VarChar(50)
  code_systeme                   String                           @unique(map: "code_systeme") @db.VarChar(20)
  institution_id                 String?                          @db.Char(36)
  statut_code                    String                           @default("inactif") @db.VarChar(50)
  endpoint                       String                           @db.VarChar(500)
  config_auth                    Json
  latence_ms                     Int                              @default(0)
  taux_erreur                    Decimal                          @default(0.00) @db.Decimal(5, 2)
  dernier_sync                   DateTime?
  volume_24h                     Int                              @default(0)
  fallback_manuel                Boolean                          @default(false)
  timeout_s                      Int                              @default(10)
  failure_threshold              Int                              @default(3)
  created_at                     DateTime                         @default(now())
  updated_at                     DateTime                         @default(now())
  beneficiaire_historique_fiscal beneficiaire_historique_fiscal[]
