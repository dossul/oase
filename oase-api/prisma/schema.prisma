generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AccordSiege {
  id                     String                 @id @default(dbgenerated("(uuid())")) @db.Char(36)
  institution            String                 @db.VarChar(200)
  typeInstitutionCode  String @map("type_institution_code")                 @db.VarChar(50)
  texteFondateur        String? @map("texte_fondateur")                @db.Text
  dateSignature         DateTime? @map("date_signature")              @db.Date
  estActif              Boolean @map("est_actif")                @default(true)
  createdAt             DateTime @map("created_at")               @default(now())
  refTypesAccordSiege RefTypeAccordSiege @relation(fields: [typeInstitutionCode], references: [code], onUpdate: NoAction, map: "accords_siege_ibfk_1")
  contribuables          Contribuable[]
  conventions            Convention[]

  @@index([typeInstitutionCode], map: "idx_type_institution_code")
  @@map("accords_siege")
}

model Acte {
  id                String         @id @default(dbgenerated("(uuid())")) @db.Char(36)
  demandeId        String @map("demande_id")         @db.Char(36)
  decisionId       String? @map("decision_id")        @db.Char(36)
  typeCode         String @map("type_code")         @db.VarChar(50)
  reference         String         @unique(map: "reference") @db.VarChar(50)
  contribuableId   String @map("contribuable_id")         @db.Char(36)
  montantFcfa      BigInt? @map("montant_fcfa")
  dateEffet        DateTime @map("date_effet")       @db.Date
  documentUrl      String @map("document_url")         @db.VarChar(500)
  hashDocument     String @map("hash_document")         @db.Char(64)
  qrCodeHash      String @map("qr_code_hash")         @db.Char(64)
  qrCodeImageUrl String? @map("qr_code_image_url")        @db.VarChar(500)
  estRevoke        Boolean @map("est_revoke")        @default(false)
  dateRevocation   DateTime? @map("date_revocation")
  motifRevocation  String? @map("motif_revocation")        @db.Text
  createdAt        DateTime @map("created_at")       @default(now())
  demandes          Demande       @relation(fields: [demandeId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "actes_ibfk_1")
  decisions         Decision?     @relation(fields: [decisionId], references: [id], onUpdate: NoAction, map: "actes_ibfk_2")
  refTypesActe    RefTypeActe @relation(fields: [typeCode], references: [code], onUpdate: NoAction, map: "actes_ibfk_3")
  contribuables     Contribuable  @relation(fields: [contribuableId], references: [id], onUpdate: NoAction, map: "actes_ibfk_4")

  @@index([demandeId, typeCode], map: "idx_actes_demande_type")
  @@index([contribuableId], map: "idx_contribuable_id")
  @@index([decisionId], map: "idx_decision_id")
  @@index([demandeId], map: "idx_demande_id")
  @@index([qrCodeHash], map: "idx_qr_code_hash")
  @@index([reference], map: "idx_reference")
  @@index([typeCode], map: "idx_type_code")
  @@map("actes")
}

model AgrementContribuable {
  id              String        @id @default(dbgenerated("(uuid())")) @db.Char(36)
  agrementId     String @map("agrement_id")        @db.Char(36)
  contribuableId String @map("contribuable_id")        @db.Char(36)
  role            String?       @db.VarChar(50)
  createdAt      DateTime @map("created_at")      @default(now())
  agrements       Agrement     @relation(fields: [agrementId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "agrement_beneficiaires_ibfk_1")
  contribuables   Contribuable @relation(fields: [contribuableId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "agrement_beneficiaires_ibfk_2")

  @@unique([agrementId, contribuableId], map: "uk_agrement_contribuable")
  @@index([agrementId], map: "idx_agrement_id")
  @@index([contribuableId], map: "idx_contribuable_id")
  @@map("agrement_contribuables")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Agrement {
  id                        String                   @id @default(dbgenerated("(uuid())")) @db.Char(36)
  reference                 String                   @unique(map: "reference") @db.VarChar(30)
  contribuableId           String @map("contribuable_id")                   @db.Char(36)
  typeAgrementCode        String @map("type_agrement_code")                   @db.VarChar(50)
  baseJuridiqueVersionId String? @map("base_juridique_version_id")                  @db.Char(36)
  regimeCode               String? @map("regime_code")                  @db.VarChar(50)
  statutCode               String @map("statut_code")                   @default("active") @db.VarChar(50)
  dateDebut                DateTime @map("date_debut")                 @db.Date
  dateFin                  DateTime @map("date_fin")                 @db.Date
  montantEstime            BigInt? @map("montant_estime")
  objet                     String?                  @db.Text
  documentUrl              String? @map("document_url")                  @db.VarChar(500)
  hashDocument             String? @map("hash_document")                  @db.Char(64)
  createdAt                DateTime @map("created_at")                 @default(now())
  updatedAt                DateTime @map("updated_at")                 @default(now())
  agrementContribuables    AgrementContribuable[]
  contribuables             Contribuable            @relation(fields: [contribuableId], references: [id], onUpdate: NoAction, map: "agrements_ibfk_1")
  refTypesAgrement        RefTypeAgrement       @relation(fields: [typeAgrementCode], references: [code], onUpdate: NoAction, map: "agrements_ibfk_2")
  baseJuridiqueVersions   BaseJuridiqueVersion? @relation(fields: [baseJuridiqueVersionId], references: [id], onUpdate: NoAction, map: "agrements_ibfk_3")
  refRegimesConvention    RefRegimeConvention?  @relation(fields: [regimeCode], references: [code], onUpdate: NoAction, map: "agrements_ibfk_4")
  refStatutsConvention    RefStatutConvention   @relation(fields: [statutCode], references: [code], onUpdate: NoAction, map: "agrements_ibfk_5")

  @@index([baseJuridiqueVersionId], map: "idx_base_juridique_version_id")
  @@index([contribuableId], map: "idx_contribuable_id")
  @@index([statutCode], map: "idx_statut_code")
  @@index([typeAgrementCode], map: "idx_type_agrement_code")
  @@index([regimeCode], map: "regime_code")
  @@map("agrements")
}

model Anomalie {
  id                        String                   @id @default(dbgenerated("(uuid())")) @db.Char(36)
  categorieCode            String @map("categorie_code")                   @db.VarChar(50)
  graviteCode              String @map("gravite_code")                   @db.VarChar(50)
  description               String                   @db.Text
  demandeId                String? @map("demande_id")                  @db.Char(36)
  baseJuridiqueVersionId String? @map("base_juridique_version_id")                  @db.Char(36)
  conventionId             String? @map("convention_id")                  @db.Char(36)
  dateDetection            DateTime @map("date_detection")                 @default(now())
  statutCode               String @map("statut_code")                   @default("nouvelle") @db.VarChar(50)
  detecteeParCode         String @map("detectee_par_code")                   @db.VarChar(50)
  utilisateurId            String? @map("utilisateur_id")                  @db.Char(36)
  regleId                  String? @map("regle_id")                  @db.VarChar(100)
  commentaire               String?                  @db.Text
  dateResolution           DateTime? @map("date_resolution")
  createdAt                DateTime @map("created_at")                 @default(now())
  updatedAt                DateTime @map("updated_at")                 @default(now())
  demandes                  Demande?                @relation(fields: [demandeId], references: [id], onUpdate: NoAction, map: "anomalies_ibfk_1")
  baseJuridiqueVersions   BaseJuridiqueVersion? @relation(fields: [baseJuridiqueVersionId], references: [id], onUpdate: NoAction, map: "anomalies_ibfk_2")
  conventions               Convention?             @relation(fields: [conventionId], references: [id], onUpdate: NoAction, map: "anomalies_ibfk_3")
  utilisateurs              Utilisateur?            @relation(fields: [utilisateurId], references: [id], onUpdate: NoAction, map: "anomalies_ibfk_4")
  refCategoriesAnomalie   RefCategorieAnomalie  @relation(fields: [categorieCode], references: [code], onUpdate: NoAction, map: "anomalies_ibfk_5")
  refGravitesAnomalie     RefGraviteAnomalie    @relation(fields: [graviteCode], references: [code], onUpdate: NoAction, map: "anomalies_ibfk_6")
  refStatutsAnomalie      RefStatutAnomalie     @relation(fields: [statutCode], references: [code], onUpdate: NoAction, map: "anomalies_ibfk_7")
  refSourcesDetection     RefSourceDetection    @relation(fields: [detecteeParCode], references: [code], onUpdate: NoAction, map: "anomalies_ibfk_8")
  reglesAnomalie           RegleAnomalie?         @relation(fields: [regleId], references: [code], onUpdate: NoAction, map: "fk_anomalies_regle")

  @@index([regleId], map: "fk_anomalies_regle")
  @@index([demandeId, graviteCode], map: "idx_anomalies_demande_gravite")
  @@index([baseJuridiqueVersionId], map: "idx_base_juridique_version_id")
  @@index([categorieCode], map: "idx_categorie_code")
  @@index([conventionId], map: "idx_convention_id")
  @@index([demandeId], map: "idx_demande_id")
  @@index([detecteeParCode], map: "idx_detectee_par_code")
  @@index([graviteCode, statutCode], map: "idx_gravite_code_statut_code")
  @@index([statutCode], map: "statut_code")
  @@index([utilisateurId], map: "utilisateur_id")
  @@map("anomalies")
}

model Archivage {
  id                    String                @id @default(dbgenerated("(uuid())")) @db.Char(36)
  typeEntite           String @map("type_entite")                @db.VarChar(50)
  entiteId             String @map("entite_id")                @db.Char(36)
  demandeId            String? @map("demande_id")               @db.Char(36)
  statutCode           String @map("statut_code")                @default("en_attente") @db.VarChar(50)
  cheminArchive        String? @map("chemin_archive")               @db.VarChar(500)
  hashArchive          String? @map("hash_archive")               @db.Char(64)
  declenchePar         String @map("declenche_par")                @default("systeme") @db.VarChar(50)
  dateArchivage        DateTime? @map("date_archivage")
  createdAt            DateTime @map("created_at")              @default(now())
  demandes              Demande?             @relation(fields: [demandeId], references: [id], onUpdate: NoAction, map: "archivages_ibfk_1")
  refStatutsArchivage RefStatutArchivage @relation(fields: [statutCode], references: [code], onUpdate: NoAction, map: "archivages_ibfk_2")

  @@index([demandeId], map: "idx_demande_id")
  @@index([statutCode], map: "idx_statut_code")
  @@index([typeEntite, entiteId], map: "idx_type_entite_entite_id")
  @@map("archivages")
}

model AuditLog {
  id               String        @id @default(dbgenerated("(uuid())")) @db.Char(36)
  horodatage       DateTime      @default(now())
  utilisateurId   String? @map("utilisateur_id")       @db.Char(36)
  roleAuMoment   String? @map("role_au_moment")       @db.VarChar(50)
  institution      String?       @db.VarChar(100)
  action           String        @db.VarChar(100)
  entite           String        @db.VarChar(50)
  entiteId        String @map("entite_id")        @db.Char(36)
  demandeId       String? @map("demande_id")       @db.Char(36)
  ancienneValeur  Json? @map("ancienne_valeur")
  nouvelleValeur  Json? @map("nouvelle_valeur")
  ip               String?       @db.VarChar(45)
  userAgent       String? @map("user_agent")       @db.Text
  hashPrecedent   String? @map("hash_precedent")       @db.Char(64)
  empreinteSha256 String @map("empreinte_sha256")        @db.Char(64)
  createdAt       DateTime @map("created_at")      @default(now())
  utilisateurs     Utilisateur? @relation(fields: [utilisateurId], references: [id], onUpdate: NoAction, map: "audit_logs_ibfk_1")
  demandes         Demande?     @relation(fields: [demandeId], references: [id], onUpdate: NoAction, map: "audit_logs_ibfk_2")

  @@index([action], map: "idx_action")
  @@index([action, entite], map: "idx_audit_logs_action_entite")
  @@index([demandeId], map: "idx_demande_id")
  @@index([entite, entiteId], map: "idx_entite_entite_id")
  @@index([horodatage], map: "idx_horodatage")
  @@index([utilisateurId], map: "idx_utilisateur_id")
  @@map("audit_logs")
}

model BaseJuridiqueDocument {
  id                        String                  @id @default(dbgenerated("(uuid())")) @db.Char(36)
  baseJuridiqueVersionId String @map("base_juridique_version_id")                  @db.Char(36)
  typeDocument             String @map("type_document")                  @db.VarChar(50)
  referenceDocument        String? @map("reference_document")                 @db.VarChar(200)
  dateDocument             DateTime? @map("date_document")               @db.Date
  nomFichier               String @map("nom_fichier")                  @db.VarChar(300)
  typeMime                 String @map("type_mime")                  @default("application/pdf") @db.VarChar(100)
  tailleOctets             BigInt? @map("taille_octets")
  urlStockage              String @map("url_stockage")                  @db.VarChar(500)
  hashSha256               String @map("hash_sha256")                  @db.Char(64)
  estTexteFondateur       Boolean @map("est_texte_fondateur")                 @default(false)
  estPublic                Boolean @map("est_public")                 @default(true)
  uploadedById            String? @map("uploaded_by_id")                 @db.Char(36)
  createdAt                DateTime @map("created_at")                @default(now())
  updatedAt                DateTime @map("updated_at")                @default(now())
  baseJuridiqueVersions   BaseJuridiqueVersion @relation(fields: [baseJuridiqueVersionId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "base_juridique_documents_ibfk_1")
  utilisateurs              Utilisateur?           @relation(fields: [uploadedById], references: [id], onUpdate: NoAction, map: "base_juridique_documents_ibfk_2")

  @@index([baseJuridiqueVersionId], map: "idx_base_juridique_version_id")
  @@index([dateDocument], map: "idx_date_document")
  @@index([estPublic], map: "idx_est_public")
  @@index([estTexteFondateur], map: "idx_est_texte_fondateur")
  @@index([typeDocument], map: "idx_type_document")
  @@index([uploadedById], map: "uploaded_by_id")
  @@map("base_juridique_documents")
}

model BaseJuridiqueVersion {
  id                         String                     @id @default(dbgenerated("(uuid())")) @db.Char(36)
  baseJuridiqueId          String @map("base_juridique_id")                     @db.Char(36)
  version                    Int                        @default(1)
  libelle                    String                     @db.Text
  impotConcerne             String @map("impot_concerne")                     @db.VarChar(100)
  natureMesureCode         String @map("nature_mesure_code")                     @db.VarChar(50)
  typeTexte1               String? @map("type_texte_1")                    @db.VarChar(100)
  typeTexte2               String? @map("type_texte_2")                    @db.VarChar(50)
  supportJuridiqueBase     String? @map("support_juridique_base")                    @db.Text
  supportJuridiqueComplem  String? @map("support_juridique_complem")                    @db.Text
  article                    String?                    @db.VarChar(200)
  articleCgi2025           String? @map("article_cgi_2025")                    @db.VarChar(100)
  porteeCategorieCode      String @map("portee_categorie_code")                     @default("Permanente") @db.VarChar(50)
  porteeDureeMois          Int? @map("portee_duree_mois")
  porteeDescription         String? @map("portee_description")                    @db.Text
  organeGestionCode        String? @map("organe_gestion_code")                    @db.VarChar(50)
  organeAttribution         String? @map("organe_attribution")                    @db.VarChar(100)
  systemeInformation        String? @map("systeme_information")                    @db.VarChar(100)
  modeInstructionCode      String @map("mode_instruction_code")                     @default("manuel") @db.VarChar(50)
  objectifType              String? @map("objectif_type")                    @db.VarChar(50)
  brancheActivite           String? @map("branche_activite")                    @db.VarChar(100)
  typeContribuableCible    String? @map("type_contribuable_cible")                    @db.VarChar(100)
  estDepenseFiscale2024   Boolean @map("est_depense_fiscale_2024")                    @default(false)
  estEvaluee2024           Boolean @map("est_evaluee_2024")                    @default(false)
  donneesDisponibles        Boolean @map("donnees_disponibles")                    @default(false)
  fonctionBudgetaire        String? @map("fonction_budgetaire")                    @db.VarChar(100)
  conformiteTexteFondament String? @map("conformite_texte_fondament")                    @db.VarChar(10)
  conformiteDirectiveUemoa String? @map("conformite_directive_uemoa")                    @db.VarChar(10)
  odd                        String?                    @db.VarChar(20)
  programmeDotation         String? @map("programme_dotation")                    @db.VarChar(100)
  positionSh                String? @map("position_sh")                    @db.VarChar(50)
  estActive                 Boolean @map("est_active")                    @default(true)
  dateAdoption              DateTime? @map("date_adoption")                  @db.Date
  dateAbrogation            DateTime? @map("date_abrogation")                  @db.Date
  validFrom                 DateTime @map("valid_from")                   @default(now())
  validTo                   DateTime? @map("valid_to")
  createdAt                 DateTime @map("created_at")                   @default(now())
  updatedAt                 DateTime @map("updated_at")                   @default(now())
  versionCouranteFlag      Int? @map("version_courante_flag")                       @db.TinyInt
  agrements                  Agrement[]
  anomalies                  Anomalie[]
  baseJuridiqueDocuments   BaseJuridiqueDocument[]
  basesJuridiques           BaseJuridique           @relation(fields: [baseJuridiqueId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "base_juridique_versions_ibfk_1")
  refNaturesMesure         RefNatureMesure         @relation(fields: [natureMesureCode], references: [code], onUpdate: NoAction, map: "base_juridique_versions_ibfk_2")
  refPorteesCategorie      RefPorteeCategorie      @relation(fields: [porteeCategorieCode], references: [code], onUpdate: NoAction, map: "base_juridique_versions_ibfk_3")
  refOrganesGestion        RefOrganeGestion?       @relation(fields: [organeGestionCode], references: [code], onUpdate: NoAction, map: "base_juridique_versions_ibfk_4")
  refModesInstruction      RefModeInstruction      @relation(fields: [modeInstructionCode], references: [code], onUpdate: NoAction, map: "base_juridique_versions_ibfk_5")
  codesAdditionnels         CodeAdditionnel[]
  conventions                Convention[]
  demandes                   Demande[]
  quotas                     Quota[]
  workflowTemplates         WorkflowTemplate[]

  @@unique([baseJuridiqueId, version], map: "uk_base_juridique_version")
  @@unique([baseJuridiqueId, versionCouranteFlag], map: "uk_une_seule_version_active")
  @@index([baseJuridiqueId], map: "idx_base_juridique_id")
  @@index([baseJuridiqueId, estActive, validTo], map: "idx_base_juridique_versions_active")
  @@index([validFrom, validTo], map: "idx_code_mesure_version")
  @@index([estActive, validTo], map: "idx_est_active_valid_to")
  @@index([impotConcerne], map: "idx_impot_concerne")
  @@index([modeInstructionCode], map: "idx_mode_instruction_code")
  @@index([organeGestionCode], map: "idx_organe_gestion_code")
  @@index([typeTexte1], map: "idx_type_texte_1")
  @@index([natureMesureCode], map: "nature_mesure_code")
  @@index([porteeCategorieCode], map: "portee_categorie_code")
  @@fulltext([libelle], map: "ft_bjv_libelle")
  @@map("base_juridique_versions")
}

model BaseJuridique {
  id                      String                    @id @default(dbgenerated("(uuid())")) @db.Char(36)
  codeMesure             String @map("code_mesure")                    @unique(map: "code_mesure") @db.VarChar(20)
  codeMesureMrd         Int? @map("code_mesure_mrd")
  createdAt              DateTime @map("created_at")                  @default(now())
  updatedAt              DateTime @map("updated_at")                  @default(now())
  baseJuridiqueVersions BaseJuridiqueVersion[]

  @@index([codeMesure], map: "idx_code_mesure")
  @@index([codeMesureMrd], map: "idx_code_mesure_mrd")
  @@map("bases_juridiques")
}

model ContribuableHistoriqueFiscal {
  id                 String             @id @default(dbgenerated("(uuid())")) @db.Char(36)
  contribuableId    String @map("contribuable_id")             @db.Char(36)
  statutFiscalCode String @map("statut_fiscal_code")             @db.VarChar(50)
  dateDebut         DateTime @map("date_debut")           @db.Date
  dateFin           DateTime? @map("date_fin")          @db.Date
  source             String?            @db.VarChar(100)
  connecteurCode    String? @map("connecteur_code")            @db.VarChar(50)
  createdAt         DateTime @map("created_at")           @default(now())
  contribuables      Contribuable      @relation(fields: [contribuableId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "beneficiaire_historique_fiscal_ibfk_1")
  refStatutsFiscal RefStatutFiscal @relation(fields: [statutFiscalCode], references: [code], onUpdate: NoAction, map: "beneficiaire_historique_fiscal_ibfk_2")
  connecteurs        Connecteur?       @relation(fields: [connecteurCode], references: [codeSysteme], onUpdate: NoAction, map: "fk_histofiscal_connecteur")

  @@index([connecteurCode], map: "fk_histofiscal_connecteur")
  @@index([contribuableId], map: "idx_contribuable_id")
  @@index([statutFiscalCode], map: "idx_statut_fiscal_code")
  @@map("contribuable_historique_fiscal")
}

model Contribuable {
  id                             String                           @id @default(dbgenerated("(uuid())")) @db.Char(36)
  raisonSociale                 String @map("raison_sociale")                           @db.VarChar(200)
  nif                            String                           @unique(map: "nif") @db.VarChar(20)
  rccm                           String?                          @db.VarChar(30)
  typeContribuableCode         String @map("type_contribuable_code")                           @db.VarChar(50)
  statutFiscalCode             String @map("statut_fiscal_code")                           @default("inconnu") @db.VarChar(50)
  secteur                        String?                          @db.VarChar(100)
  region                         String?                          @db.VarChar(100)
  emailContact                  String? @map("email_contact")                          @db.VarChar(200)
  telephone                      String?                          @db.VarChar(20)
  adresse                        String?                          @db.Text
  accordSiegeId                String? @map("accord_siege_id")                          @db.Char(36)
  userId                        String? @map("user_id")                          @unique(map: "user_id") @db.Char(36)
  createdAt                     DateTime @map("created_at")                         @default(now())
  updatedAt                     DateTime @map("updated_at")                         @default(now())
  actes                          Acte[]
  agrementContribuables         AgrementContribuable[]
  agrements                      Agrement[]
  contribuableHistoriqueFiscal ContribuableHistoriqueFiscal[]
  accordsSiege                  AccordSiege?                   @relation(fields: [accordSiegeId], references: [id], onUpdate: NoAction, map: "beneficiaires_ibfk_1")
  refTypesContribuable         RefTypeContribuable           @relation(fields: [typeContribuableCode], references: [code], onUpdate: NoAction, map: "beneficiaires_ibfk_2")
  refStatutsFiscal             RefStatutFiscal               @relation(fields: [statutFiscalCode], references: [code], onUpdate: NoAction, map: "beneficiaires_ibfk_3")
  utilisateurs                   Utilisateur?                    @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "beneficiaires_ibfk_4")
  conventions                    Convention[]
  demandes                       Demande[]
  quotas                         Quota[]

  @@index([accordSiegeId], map: "idx_accord_siege_id")
  @@index([nif], map: "idx_nif")
  @@index([statutFiscalCode], map: "idx_statut_fiscal_code")
  @@index([typeContribuableCode], map: "idx_type_contribuable_code")
  @@fulltext([raisonSociale], map: "ft_contribuables")
  @@map("contribuables")
}

model CodeAdditionnel {
  id                        String                  @id @default(dbgenerated("(uuid())")) @db.Char(36)
  baseJuridiqueVersionId String @map("base_juridique_version_id")                  @db.Char(36)
  code                      String                  @db.VarChar(50)
